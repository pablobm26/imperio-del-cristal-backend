ADMIN_PASSWORD=elige-una-contraseña-fuerte-aqui
PORT=3000
ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui
# Solo en Render, si activaste un disco persistente: la ruta donde lo montaste (ej. /var/data).
# Sin esta variable, los datos (catálogo, reseñas) se guardan en una carpeta local que Render borra
# en cada redeploy si el servicio no tiene disco.
DATA_DIR=

# Sincronización automática con PLADE SOFTWARE (getInventario). Si dejas estas 3 vacías, el
# catálogo sigue viniendo del CSV subido manualmente en /admin, sin ningún cambio de comportamiento.
# Ver E:\DESCARGAS\API IMPERIO DEL CRISTAL.pdf (manual de PLADE) para los valores reales.
PLADE_USER=
PLADE_PASSWORD=
PLADE_TOKEN=
